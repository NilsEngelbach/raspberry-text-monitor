extends layout.pug

block content
  h1 #{song.name}

  div#lyrics(class=(flex ? 'flex' : '' )) !{lyrics}


block footer
  footer(style="margin-top: 300px;")
    .left
      .button.click(onclick='scrollUp()') 
        span.icon.left-click
        .text UP
      if prevSong
        .button.hold(onclick='prev()')
          span.icon.left-hold
          .text#prev(title=prevSong.filename) #{prevSong.name}
    .middle
      .button.click(onclick='setlist()')
        span.icon.middle-click
        .text SETLIST
    .right
      .button.click(onclick='scrollDown()')
        span.icon.right-click
        .text DOWN
      if nextSong
        .button.hold(onclick='next()')
          span.icon.right-hold
          .text#next(title=nextSong.filename) #{nextSong.name}


block scripts
  script.
    function setlist() {
      location.href = "/?song=" + location.pathname.substring(1, location.pathname.length);
    }

    function prev() {
      let prevSong = document.getElementById('prev');
      if (prevSong) {
        location.href = `/${prevSong.title}`;
      }
    }

    function next() {
      let nextSong = document.getElementById('next');
        if (nextSong) {
          location.href = `/${nextSong.title}`;
        }
    }

    function scrollDown() {
      document.getElementById("container").scrollBy(0, window.innerHeight / 2);
    }

    function scrollUp() {
      document.getElementById("container").scrollBy(0, -(window.innerHeight / 2));
    }


    addEventListener("shortPress", (e) => {
      if (e.detail.button == "left") {
        scrollUp();
      }
      if (e.detail.button == "middle") {
        setlist();
      }
      if (e.detail.button == "right") {
        scrollDown();
      }
    });

    addEventListener("longPress", (e) => {
      if (e.detail.button == "left") {
        prev();
      }
      if (e.detail.button == "right") {
        next();
      }
    });

block socketScript
  script.
    if (new URLSearchParams(location.search).has('preview')) { void 0; } else {
      const socket = io();
      socket.emit('identify', { role: 'pi' });

      function piScreenState() {
        return {
          screenW: window.innerWidth,
          screenH: window.innerHeight,
          dpr: window.devicePixelRatio || 1,
        };
      }

      socket.emit('pi:state', {
        view: 'song',
        filename: '#{song.filename}',
        songName: '#{song.name}',
        scrollPercent: 0,
        ...piScreenState(),
      });

      window.addEventListener('resize', () => {
        socket.emit('pi:state', piScreenState());
      });

      let scrollTimer;
      document.getElementById('container').addEventListener('scroll', () => {
        clearTimeout(scrollTimer);
        scrollTimer = setTimeout(() => {
          const el = document.getElementById('container');
          const max = el.scrollHeight - el.clientHeight;
          const pct = max > 0 ? Math.round((el.scrollTop / max) * 100) : 0;
          socket.emit('pi:state', { scrollPercent: pct });
        }, 200);
      });

      socket.on('command:navigate', ({ direction }) => {
        if (direction === 'next') next();
        if (direction === 'prev') prev();
      });

      socket.on('command:scroll', ({ direction }) => {
        if (direction === 'down') scrollDown();
        if (direction === 'up') scrollUp();
      });

      socket.on('command:goto', ({ filename }) => {
        location.href = '/' + filename;
      });
      
      socket.on('command:setlist', () => setlist());
    } // end preview guard
