extends layout.pug

block content
  #setlist
    h1 Settings
    if error
      h3.highlight Setlist auswählen:

  form(role='form', method='POST', id='select-setlist')
    each setlist, index in setlists
      div
        input(type='radio', name='setlist', value=index, id=index)
        label(for=index) #{setlist}

block footer
  footer(style="margin-top: 300px;")
    .left
      .button.click(onclick='prev()')
        span.icon.left-click
        .text UP
    .middle
      .button.click(onclick='select()')
        span.icon.middle-click
        .text SELECT
      .button.hold(onclick='menu()')
        span.icon.middle-hold
        .text MENU
    .right
      .button.click(onclick='next()')
        span.icon.right-click
        .text DOWN

block scripts
  script.

    var setlist = 0;
    var total = #{setlists.length};

    function menu() {
      location.href = "/";
    }

    function next() {
      setlist++;
      if (setlist == total) {
        setlist = 0;
      }
      document.forms["select-setlist"][setlist].checked = true;
    }

    function prev() {
      setlist--;
      if (setlist == -1) {
        setlist = total - 1;
      }
      document.forms["select-setlist"][setlist].checked = true;
    }

    function select() {
      document.forms["select-setlist"].submit();
    }

    addEventListener("shortPress", (e) => {
      if (e.detail.button == "left") {
        prev();
      }
      if (e.detail.button == "middle") {
        select();
      }
      if (e.detail.button == "right") {
        next();
      }
    });

    addEventListener("longPress", (e) => {
      if (e.detail.button == "middle") {
        menu();
      }
    });

    addEventListener("load", (e) => {
      let urlParams = new URLSearchParams(location.search);
      let initialIndex = urlParams.has('selected') ? parseInt(urlParams.get('selected')) : #{selectedIndex};
      if (initialIndex >= 0) {
        setlist = initialIndex;
        document.forms["select-setlist"][initialIndex].checked = true;
      }
    });

block socketScript
  script.
    if (new URLSearchParams(location.search).has('preview')) { void 0; } else {
      const socket = io();
      socket.emit('identify', { role: 'pi' });

      function emitSettingsState() {
        socket.emit('pi:state', {
          view: 'settings',
          filename: null,
          songName: null,
          scrollPercent: 0,
          selectedIndex: setlist,
          screenW: window.innerWidth,
          screenH: window.innerHeight,
          dpr: window.devicePixelRatio || 1,
        });
      }

      emitSettingsState();

      const _origNext = next, _origPrev = prev;
      next = function() { _origNext(); socket.emit('pi:state', { selectedIndex: setlist }); };
      prev = function() { _origPrev(); socket.emit('pi:state', { selectedIndex: setlist }); };

      window.addEventListener('resize', () => {
        socket.emit('pi:state', {
          screenW: window.innerWidth,
          screenH: window.innerHeight,
          dpr: window.devicePixelRatio || 1,
        });
      });
    } // end preview guard
